{
  "_meta": {
    "scope": "common",
    "description": "Globally reusable UI strings. Keys promoted here appear on 3+ pages or are structural chrome with no page-specific meaning. For strings shared within a single arc or page scope, use {scope}.common.{element}.{name} keys in the scope's own file.",
    "keyConvention": "common.{element-type}.{semantic-name}",
    "elementTypes": ["button", "label", "heading", "description", "nav", "legend", "status", "placeholder"],
    "valueShape": "Each key maps to an element object. 'strings' is the only namespace now; future namespaces (testId, dataKey, designToken) extend the same object without breaking existing readers."
  },

  "common.nav.prev": {
    "strings": {
      "en": { "text": "← prev", "aria-label": "Previous page" },
      "ja": { "text": "← 前へ", "aria-label": "前のページ" }
    }
  },
  "common.nav.next": {
    "strings": {
      "en": { "text": "next →", "aria-label": "Next page" },
      "ja": { "text": "次へ →", "aria-label": "次のページ" }
    }
  },
  "common.label.you-are-here": {
    "strings": {
      "en": { "text": "You Are Here" },
      "ja": { "text": "現在地" }
    }
  },

